{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "A contact message from a user",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The sender's name" },
        "email": { "type": "string", "description": "The sender's email" },
        "subject": { "type": "string", "description": "The message subject" },
        "message": { "type": "string", "description": "The message content" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the message was sent" }
      },
      "required": ["name", "email", "subject", "message", "createdAt"]
    }
  },
  "firestore": {
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Collection of contact messages"
    }
  }
}
